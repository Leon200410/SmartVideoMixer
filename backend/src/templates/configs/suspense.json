{
  "id": "suspense",
  "name": "悬念引流",
  "description": "开头+高能+结尾，AI大字标题拉满好奇心，结尾引导关注",
  "tag": "涨粉款",
  "segmentSelection": {
    "strategy": "first-best-last",
    "maxSegments": 3,
    "minDuration": 3,
    "maxDuration": 10
  },
  "layout": {
    "outro": {
      "duration": 2,
      "type": "text",
      "text": "关注我获取更多精彩",
      "style": {
        "backgroundColor": "#000000",
        "textColor": "#FFFFFF",
        "fontSize": 70
      }
    }
  },
  "transitions": {
    "type": "fade",
    "duration": 0.5
  },
  "visualStyle": {
    "filter": "cinematic",
    "brightness": -0.05,
    "contrast": 0.2,
    "saturation": 0
  },
  "textOverlay": {
    "enabled": true,
    "position": "center",
    "fontSize": 60,
    "fontColor": "#FFFFFF",
    "backgroundColor": "black@0.5",
    "generateWithAI": true
  },
  "backgroundMusic": {
    "enabled": true,
    "file": "dramatic.mp3",
    "volume": 0.25,
    "fadeIn": 0.5,
    "fadeOut": 1.5
  },
  "audioProcessing": {
    "keepOriginal": true,
    "originalVolume": 0.8,
    "normalize": true
  }
}
