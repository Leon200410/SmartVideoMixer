{
  "id": "cinematic",
  "name": "电影质感",
  "description": "慢节奏剪辑，电影滤镜，淡入淡出转场，适合风景和情感类内容",
  "tag": "高级感",
  "segmentSelection": {
    "strategy": "top-scored",
    "maxSegments": 4,
    "minDuration": 4,
    "maxDuration": 12,
    "sortBy": "time"
  },
  "layout": {
    "intro": {
      "duration": 1.1,
      "type": "text",
      "text": "CINEMATIC",
      "style": {
        "backgroundColor": "#000000",
        "textColor": "#FFFFFF",
        "fontSize": 82
      }
    }
  },
  "transitions": {
    "type": "fade",
    "duration": 0.75,
    "variety": ["fade", "dissolve", "fadeblack"]
  },
  "pacing": {
    "pattern": [5, 6.5, 8, 8],
    "speed": 0.85
  },
  "visualStyle": {
    "filter": "cinematic",
    "brightness": -0.06,
    "contrast": 0.2,
    "saturation": -0.08,
    "kenBurns": true
  },
  "backgroundMusic": {
    "enabled": true,
    "file": "ambient.mp3",
    "jamendoTags": ["ambient", "soundtrack", "piano"],
    "jamendoVocal": "instrumental",
    "volume": 0.65,
    "fadeIn": 1.4,
    "fadeOut": 2.2
  },
  "audioProcessing": {
    "keepOriginal": true,
    "originalVolume": 0.7,
    "normalize": true
  }
}
