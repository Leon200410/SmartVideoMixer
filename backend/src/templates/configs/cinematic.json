{
  "id": "cinematic",
  "name": "电影质感",
  "description": "暗调电影风，慢节奏、柔和推拉、低饱和光影，适合情绪和风景内容",
  "tag": "电影感",
  "segmentSelection": {
    "strategy": "top-scored",
    "maxSegments": 5,
    "minDuration": 3,
    "maxDuration": 9,
    "sortBy": "time"
  },
  "layout": {
    "intro": {
      "duration": 1.1,
      "type": "text",
      "text": "FILM LOOK",
      "style": {
        "backgroundColor": "#000000",
        "textColor": "#FFFFFF",
        "fontSize": 82
      }
    }
  },
  "transitions": {
    "type": "fade",
    "duration": 0.8,
    "variety": ["fade", "dissolve", "fadeblack"]
  },
  "pacing": {
    "pattern": [4, 5, 6, 6],
    "speed": 0.92
  },
  "visualStyle": {
    "filter": "cinematic",
    "brightness": -0.05,
    "contrast": 0.12,
    "saturation": -0.16,
    "kenBurns": true
  },
  "backgroundMusic": {
    "enabled": true,
    "file": "ambient.mp3",
    "jamendoTags": ["ambient", "soundtrack", "piano"],
    "jamendoVocal": "instrumental",
    "volume": 0.5,
    "fadeIn": 1.4,
    "fadeOut": 2.4
  },
  "audioProcessing": {
    "keepOriginal": true,
    "originalVolume": 0.72,
    "normalize": true
  }
}
