{
  "id": "highlights",
  "name": "高光混剪",
  "description": "快节奏卡点混剪，高对比、高饱和、短促滑动转场，适合精彩瞬间",
  "tag": "爆点款",
  "segmentSelection": {
    "strategy": "top-scored",
    "maxSegments": 7,
    "minDuration": 1.4,
    "maxDuration": 5.5,
    "sortBy": "time"
  },
  "layout": {
    "intro": {
      "duration": 0.6,
      "type": "text",
      "text": "高光时刻",
      "style": {
        "backgroundColor": "#000000",
        "textColor": "#FFFFFF",
        "fontSize": 72
      }
    }
  },
  "transitions": {
    "type": "slide",
    "duration": 0.26,
    "variety": ["slideleft", "wipeleft", "slideright", "smoothup", "hlslice"]
  },
  "pacing": {
    "hook": {
      "enabled": true,
      "duration": 0.9
    },
    "pattern": [1.6, 1.8, 2.1, 2.4, 3]
  },
  "visualStyle": {
    "filter": "vibrant",
    "brightness": 0.05,
    "contrast": 0.18,
    "saturation": 0.22,
    "kenBurns": true
  },
  "backgroundMusic": {
    "enabled": true,
    "file": "upbeat.mp3",
    "jamendoTags": ["electronic", "dance", "upbeat"],
    "jamendoVocal": "instrumental",
    "volume": 0.58,
    "fadeIn": 0.6,
    "fadeOut": 1.4
  },
  "audioProcessing": {
    "keepOriginal": true,
    "originalVolume": 0.85,
    "normalize": true
  }
}
