# Environment variables
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# 可选：Gemini API 中转站/代理地址（留空 = 直连 Google 官方）
# 例如 GEMINI_BASE_URL=https://your-relay.example.com
GEMINI_BASE_URL=
# 可选：API 协议格式。native = Gemini 原生协议（默认）；
# openai = OpenAI 兼容格式（大部分 one-api/new-api 中转站用这个）
GEMINI_PROTOCOL=native
PORT=8000

# Cloudflare R2 (Optional, 10GB free)
R2_ENABLED=false
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=smart-video-mixer
R2_PUBLIC_URL=https://your-r2-public-url.com

# File cleanup
CLEANUP_INTERVAL_HOURS=2
MAX_FILE_AGE_HOURS=2
