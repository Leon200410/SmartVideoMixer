{
  "name": "smart-video-mixer-backend",
  "version": "1.0.0",
  "description": "AI-powered video mixing backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/templates/configs','dist/templates/configs',{recursive:true})\"",
    "start": "node dist/index.js",
    "clean": "rimraf dist"
  },
  "keywords": [
    "video",
    "ai",
    "ffmpeg",
    "ark"
  ],
  "engines": {
    "node": ">=23.4"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@remotion/bundler": "4.0.475",
    "@remotion/renderer": "4.0.475",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.2.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "4.0.475",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/fs-extra": "^11.0.4",
    "@types/multer": "^1.4.11",
    "@types/node": "^24.13.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "rimraf": "^5.0.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
